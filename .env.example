# MongoDB
MONGODB_URI=mongodb://localhost:27017/resourceflow

# NextAuth
NEXTAUTH_SECRET=replace-with-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=resourceflow-dev
# Optional: prefix every S3 key with this folder (useful when sharing a bucket)
S3_KEY_PREFIX=resourceflow

# Email — Amazon SES (preferred backend)
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1
EMAIL_FROM=ResourceFlow <no-reply@yourdomain.com>

# SMTP fallback (used when SES is not configured or fails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ResourceFlow <no-reply@yourdomain.com>

# Optional: rate limit (requests per 15min per IP for /api/auth)
AUTH_RATE_LIMIT_MAX=5
